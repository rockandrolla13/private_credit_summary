**RiskFreeCurve Class:**

```python
import numpy as np

class RiskFreeCurve:
    """Risk-free discount curve."""
    
    def __init__(self, tenors: np.ndarray, spot_rates: np.ndarray):
        """
        Parameters:
        -----------
        tenors : array
            Maturities in years [0.25, 0.5, 1, 2, ...]
        spot_rates : array
            Zero-coupon rates as decimals [0.025, 0.027, ...]
        """
        self.tenors = np.array(tenors)
        self.spot_rates = np.array(spot_rates)
        self.discount_factors = np.exp(-self.spot_rates * self.tenors)
        self.log_discount_factors = np.log(self.discount_factors)
    
    def discount_factor(self, t: float) -> float:
        """Get B(t) via interpolation."""
        if t <= 0:
            return 1.0
        
        if t >= self.tenors[-1]:
            # Flat extrapolation
            excess = t - self.tenors[-1]
            return self.discount_factors[-1] * np.exp(-self.spot_rates[-1] * excess)
        
        # Linear interpolation of log(B(t))
        log_B = np.interp(t, self.tenors, self.log_discount_factors)
        return np.exp(log_B)
    
    def spot_rate(self, t: float) -> float:
        """Get r(t) via interpolation."""
        if t <= 0:
            return self.spot_rates[0]
        
        if t >= self.tenors[-1]:
            return self.spot_rates[-1]
        
        return np.interp(t, self.tenors, self.spot_rates)
    
    def forward_rate(self, t: float, dt: float = 0.001) -> float:
        """
        Instantaneous forward rate f(t).
        
        f(t) = -d[log B(t)]/dt
        """
        if t <= 0:
            t = dt
        
        B_t = self.discount_factor(t)
        B_t_plus = self.discount_factor(t + dt)
        
        f_t = -(np.log(B_t_plus) - np.log(B_t)) / dt
        
        return f_t
```

### 9.2 Helper Functions

**Survival Probability:**

```python
def survival_prob(t: float, theta: np.ndarray) -> float:
    """
    Calculate Q(t; θ).
    
    Q(t) = exp[-λ₀ t - (λ₁/β)(1 - exp(-β t))]
    """
    if t <= 0:
        return 1.0
    
    lambda_0, lambda_1, beta = theta
    
    cum_hazard = lambda_0 * t + (lambda_1 / beta) * (1 - np.exp(-beta * t))
    
    return np.exp(-cum_hazard)
```

**Expected Loss:**

```python
def calculate_expected_loss(T: float, theta: np.ndarray, rf_curve) -> float:
    """
    Calculate Ξ(T) = ∫₀ᵀ B(t)dQ(t).
    """
    # Quarterly grid
    m = int(T * 4) + 1
    t_grid = np.linspace(0, T, m)
    
    expected_loss = 0.0
    
    for i in range(1, m):
        t_mid = (t_grid[i-1] + t_grid[i]) / 2
        B_mid = rf_curve.discount_factor(t_mid)
        Q_prev = survival_prob(t_grid[i-1], theta)
        Q_curr = survival_prob(t_grid[i], theta)
        dQ = Q_prev - Q_curr
        
        expected_loss += B_mid * dQ
    
    return expected_loss
```

**Risky PV01:**

```python
def calculate_risky_pv01(T: float, theta: np.ndarray, rf_curve) -> float:
    """
    Calculate Π(T) = ∫₀ᵀ B(t)Q(t)dt.
    """
    m = int(T * 4) + 1
    t_grid = np.linspace(0, T, m)
    
    integrand = np.array([
        rf_curve.discount_factor(t) * survival_prob(t, theta)
        for t in t_grid
    ])
    
    Pi = np.trapz(integrand, t_grid)
    
    return Pi
```

**Risky-Weighted Forward Rate:**

```python
def calculate_risky_weighted_forward(T: float, theta: np.ndarray, rf_curve) -> float:
    """
    Calculate r_b(T) = [∫₀ᵀ f(t)B(t)Q(t)dt] / Π(T).
    """
    m = int(T * 4) + 1
    t_grid = np.linspace(0, T, m)
    
    f_values = np.array([rf_curve.forward_rate(t) for t in t_grid])
    BQ_values = np.array([
        rf_curve.discount_factor(t) * survival_prob(t, theta)
        for t in t_grid
    ])
    
    numerator = np.trapz(f_values * BQ_values, t_grid)
    denominator = np.trapz(BQ_values, t_grid)
    
    r_b = numerator / denominator
    
    return r_b
```

