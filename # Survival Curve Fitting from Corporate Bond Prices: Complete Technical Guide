def remove_outliers(bonds, rf_curve, threshold=5.0):
    """
    Iteratively remove bonds with large pricing errors.
    """
    clean_bonds = bonds.copy()
    
    while len(clean_bonds) >= 3:
        result = fit_survival_curve(clean_bonds, rf_curve, verbose=False)
        
        if not result['success']:
            break
        
        # Find worst bond
        residuals = result['residuals']
        abs_residuals = np.abs(residuals)
        worst_idx = np.argmax(abs_residuals)
        worst_error = abs_residuals[worst_idx]
        
        if worst_error > threshold:
            print(f"Removing outlier: {clean_bonds[worst_idx].isin} (error: {worst_error:.2f})")
            clean_bonds.pop(worst_idx)
        else:
            break
    
    return clean_bonds

