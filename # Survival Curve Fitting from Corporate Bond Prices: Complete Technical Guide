### 10.3 Cross-Validation

**Leave-One-Out Validation:**

```python
def cross_validate_curve(bonds, rf_curve, recovery=0.40):
    """
    Leave-one-out cross-validation.
    
    Fit curve excluding each bond, then check pricing error on held-out bond.
    """
    loo_errors = []
    
    for i in range(len(bonds)):
        # Hold out bond i
        train_bonds = bonds[:i] + bonds[i+1:]
        test_bond = bonds[i]
        
        if len(train_bonds) < 3:
            continue  # Need at least 3 to fit
        
        # Fit on training set
        result = fit_survival_curve(train_bonds, rf_curve, recovery, verbose=False)
        
        if not result['success']:
            continue
        
        theta = result['theta']
        
        # Price held-out bond
        if test_bond.callable:
            model_price = price_bond_tree(test_bond, theta, rf_curve, recovery)
        else:
            model_price = price_bond_analytical(test_bond, theta, rf_curve, recovery)
        
        error = model_price - test_bond.price
        loo_errors.append({
            'bond': test_bond.isin,
            'maturity': test_bond.maturity,
            'error': error
        })
    
    # Calculate LOO RMSE
    errors = [e['error'] for e in loo_errors]
    loo_rmse = np.sqrt(np.mean(np.array(errors)**2))
    
    return {
        'loo_errors': loo_errors,
        'loo_rmse': loo_rmse
    }
```

