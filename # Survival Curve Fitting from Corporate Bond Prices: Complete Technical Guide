## 8. Complete Algorithm

### 8.1 Algorithm Overview

```
INPUT:
  - List of bonds for issuer: {b₁, b₂, ..., bₙ}
  - Risk-free curve: rf_curve
  - Recovery rate: ℜ (default 0.40)

OUTPUT:
  - Fitted survival curve parameters: θ* = [λ₀, λ₁, β]
  - Fit quality metrics: RMSE, residuals

ALGORITHM:
  1. Validate input data
  2. Generate initial guess θ₀
  3. Define objective function r(θ)
  4. Run constrained optimization
  5. Validate fitted curve
  6. Return results
```

### 8.2 Detailed Algorithm Steps

**STEP 1: Validate Input Data**

```python
def validate_bonds(bonds):
    """
    Check bond data quality.
    """
    if len(bonds) < 3:
        raise ValueError(f"Need at least 3 bonds, have {len(bonds)}")
    
    for bond in bonds:
        if bond.maturity <= 0:
            raise ValueError(f"Invalid maturity: {bond.maturity}")
        
        if bond.coupon < 0:
            raise ValueError(f"Invalid coupon: {bond.coupon}")
        
        if bond.price <= 0 or bond.price > 200:
            raise ValueError(f"Suspicious price: {bond.price}")
        
        if bond.callable and bond.call_schedule is None:
            raise ValueError(f"Callable bond missing call schedule")
    
    return True
```

**STEP 2: Generate Initial Guess**

```python
def initial_guess(bonds, rf_curve):
    """
    Generate θ₀ from bond data.
    """
    # Find longest non-callable bond
    non_callable = [b for b in bonds if not b.callable]
    
    if non_callable:
        reference_bond = max(non_callable, key=lambda b: b.maturity)
    else:
        reference_bond = max(bonds, key=lambda b: b.maturity)
    
    T = reference_bond.maturity
    P = reference_bond.price
    
    # Estimate default probability
    PD_est = max(0.01, min(0.99, (100 - P) / 100))
    
    # Estimate λ₀
    lambda_0 = -np.log(1 - PD_est) / T
    lambda_0 = np.clip(lambda_0, 0.001, 0.1)
    
    # Set λ₁ and β
    lambda_1 = 0.5 * lambda_0
    beta = np.log(2) / 2  # 2-year half-life
    
    theta_0 = np.array([lambda_0, lambda_1, beta])
    
    return theta_0
```

**STEP 3: Define Objective Function**

```python
def create_objective_function(bonds, rf_curve, recovery):
    """
    Return objective function r(θ) for optimization.
    """
    def objective(theta):
        """
        Calculate residuals for all bonds.
        """
        residuals = []
        
        for bond in bonds:
            # Price bond with current theta
            if bond.callable or bond.puttable:
                model_price = price_bond_tree(bond, theta, rf_curve, recovery)
            else:
                model_price = price_bond_analytical(bond, theta, rf_curve, recovery)
            
            # Calculate error
            market_price = bond.price
            residual = model_price - market_price
            
            residuals.append(residual)
        
        return np.array(residuals)
    
    return objective
```

**STEP 4: Run Optimization**

```python
def optimize_survival_curve(objective, theta_0, bounds):
    """
    Run constrained least-squares optimization.
    """
    from scipy.optimize import least_squares
    
    result = least_squares(
        fun=objective,
        x0=theta_0,
        bounds=(
            [bounds['lambda_0'][0], bounds['lambda_1'][0], bounds['beta'][0]],
            [bounds['lambda_0'][1], bounds['lambda_1'][1], bounds['beta'][1]]
        ),
        method='trf',
        ftol=1e-8,
        xtol=1e-8,
        gtol=1e-8,
        max_nfev=200,
        verbose=0
    )
    
    return result
```

**STEP 5: Validate Fitted Curve**

```python
def validate_fitted_curve(theta, bonds, rf_curve, recovery):
    """
    Run validation checks on fitted curve.
    """
    lambda_0, lambda_1, beta = theta
    
    checks = {}
    
    # Check 1: Positive hazard rates
    t_grid = np.linspace(0, 30, 100)
    hazard_rates = lambda_0 + lambda_1 * np.exp(-beta * t_grid)
    checks['positive_hazard'] = np.all(hazard_rates > 0)
    
    # Check 2: Monotonic survival probabilities
    Q_values = [survival_prob(t, theta) for t in t_grid]
    checks['monotonic_survival'] = all(Q_values[i] >= Q_values[i+1] 
                                       for i in range(len(Q_values)-1))
    
    # Check 3: RMSE threshold
    residuals = []
    for bond in bonds:
        if bond.callable:
            model_price = price_bond_tree(bond, theta, rf_curve, recovery)
        else:
            model_price = price_bond_analytical(bond, theta, rf_curve, recovery)
        
        residuals.append(model_price - bond.price)
    
    rmse = np.sqrt(np.mean(np.array(residuals)**2))
    checks['rmse'] = rmse
    checks['rmse_acceptable'] = rmse < 5.0
    
    # Check 4: No individual outliers
    max_abs_residual = np.max(np.abs(residuals))
    checks['max_residual'] = max_abs_residual
    checks['max_residual_acceptable'] = max_abs_residual < 10.0
    
    # Check 5: Parity equation (for non-callable bonds)
    parity_errors = []
    for bond in bonds:
        if not bond.callable:
            T = bond.maturity
            
            B_T = rf_curve.discount_factor(T)
            Q_T = survival_prob(T, theta)
            Xi = calculate_expected_loss(T, theta, rf_curve)
            Pi = calculate_risky_pv01(T, theta, rf_curve)
            r_b = calculate_risky_weighted_forward(T, theta, rf_curve)
            
            lhs = B_T * Q_T + Xi + r_b * Pi
            parity_error = abs(lhs - 1.0)
            parity_errors.append(parity_error)
    
    if parity_errors:
        checks['max_parity_error'] = max(parity_errors)
        checks['parity_valid'] = max(parity_errors) < 1e-6
    
    return checks
```

**STEP 6: Complete Fitting Function**

```python
def fit_survival_curve(bonds, rf_curve, recovery=0.40, verbose=True):
    """
    Complete survival curve fitting procedure.
    
    Parameters:
    -----------
    bonds : list of Bond objects
        At least 3 bonds required
    rf_curve : RiskFreeCurve object
    recovery : float
        Recovery rate (default 0.40)
    verbose : bool
        Print progress messages
    
    Returns:
    --------
    result : dict
        {
            'theta': fitted parameters [lambda_0, lambda_1, beta],
            'rmse': root mean squared error,
            'residuals': individual bond pricing errors,
            'success': optimization success flag,
            'validation': validation check results
        }
    """
    # Step 1: Validate
    validate_bonds(bonds)
    
    if verbose:
        print(f"Fitting survival curve to {len(bonds)} bonds")
        n_callable = sum(1 for b in bonds if b.callable)
        print(f"  Bullets: {len(bonds) - n_callable}, Callables: {n_callable}")
    
    # Step 2: Initial guess
    theta_0 = initial_guess(bonds, rf_curve)
    
    if verbose:
        print(f"  Initial guess: λ₀={theta_0[0]:.6f}, λ₁={theta_0[1]:.6f}, β={theta_0[2]:.6f}")
    
    # Step 3: Create objective
    objective = create_objective_function(bonds, rf_curve, recovery)
    
    # Step 4: Optimize
    bounds = {
        'lambda_0': [1e-5, 0.5],
        'lambda_1': [-1.0, 1.0],
        'beta': [0.01, 10.0]
    }
    
    opt_result = optimize_survival_curve(objective, theta_0, bounds)
    
    theta_optimal = opt_result.x
    residuals = opt_result.fun
    rmse = np.sqrt(np.mean(residuals**2))
    
    if verbose:
        print(f"  Optimization {'succeeded' if opt_result.success else 'FAILED'}")
        print(f"  Final: λ₀={theta_optimal[0]:.6f}, λ₁={theta_optimal[1]:.6f}, β={theta_optimal[2]:.6f}")
        print(f"  RMSE: {rmse:.3f} points")
    
    # Step 5: Validate
    validation = validate_fitted_curve(theta_optimal, bonds, rf_curve, recovery)
    
    if verbose:
        print(f"  Validation:")
        print(f"    Positive hazard: {validation['positive_hazard']}")
        print(f"    Monotonic survival: {validation['monotonic_survival']}")
        print(f"    RMSE acceptable: {validation['rmse_acceptable']}")
        if 'parity_valid' in validation:
            print(f"    Parity valid: {validation['parity_valid']}")
    
    # Step 6: Return
    return {
        'theta': theta_optimal,
        'rmse': rmse,
        'residuals': residuals,
        'success': opt_result.success,
        'validation': validation,
        'optimizer_message': opt_result.message
    }
```

