    checks['Q_0'] = Q_values[0]
    checks['Q_0_valid'] = abs(Q_values[0] - 1.0) < 1e-10
    
    # Q(t) should be monotonic decreasing
    is_monotonic = all(Q_values[i] >= Q_values[i+1] for i in range(len(Q_values)-1))
    checks['survival_monotonic'] = is_monotonic
    
    # Q(t) should be in [0, 1]
    checks['survival_bounded'] = all(0 <= q <= 1 for q in Q_values)
    
    # === CHECK 4: Pricing Errors ===
    residuals = []
    abs_residuals = []
    
    for bond in bonds:
        if bond.callable:
            model_price = price_bond_tree(bond, theta, rf_curve, recovery)
        else:
            model_price = price_bond_analytical(bond, theta, rf_curve, recovery)
        
        residual = model_price - bond.price
        residuals.append(residual)
        abs_residuals.append(abs(residual))
    
    checks['residuals'] = residuals
    checks['rmse'] = np.sqrt(np.mean(np.array(residuals)**2))
    checks['max_abs_residual'] = max(abs_residuals)
    checks['mean_residual'] = np.mean(residuals)
    
    # Quality thresholds
    checks['rmse_excellent'] = checks['rmse'] < 1.0
    checks['rmse_good'] = checks['rmse'] < 2.0
    checks['rmse_acceptable'] = checks['rmse'] < 5.0
    checks['no_large_outliers'] = checks['max_abs_residual'] < 10.0
    checks['unbiased'] = abs(checks['mean_residual']) < 1.0
    
    # === CHECK 5: Parity Equation ===
    parity_errors = []
    
    for bond in bonds:
        if not bond.callable:  # Only for non-callable
            T = bond.maturity
            
            B_T = rf_curve.discount_factor(T)
            Q_T = survival_prob(T, theta)
            Xi = calculate_expected_loss(T, theta, rf_curve)
            Pi = calculate_risky_pv01(T, theta, rf_curve)
            r_b = calculate_risky_weighted_forward(T, theta, rf_curve)
            
            lhs = B_T * Q_T + Xi + r_b * Pi
            parity_error = abs(lhs - 1.0)
            parity_errors.append(parity_error)
    
    if parity_errors:
        checks['parity_errors'] = parity_errors
        checks['max_parity_error'] = max(parity_errors)
        checks['parity_valid'] = max(parity_errors) < 1e-6
    
    # === CHECK 6: Default Probabilities ===
    test_horizons = [1, 2, 3, 5, 10]
    default_probs = {}
    
    for T in test_horizons:
        if T <= max(b.maturity for b in bonds):
            PD = 1 - survival_prob(T, theta)
            default_probs[f'{T}Y'] = PD
    
    checks['default_probs'] = default_probs
    
    # Sanity check: 5Y default prob should be reasonable
    if '5Y' in default_probs:
        PD_5Y = default_probs['5Y']
        checks['5Y_PD_reasonable'] = (0.001 <= PD_5Y <= 0.50)
    
    # === CHECK 7: Term Structure ===
    if len(test_horizons) >= 2:
        # Check if term structure is plausible
        PDs = [1 - survival_prob(T, theta) for T in test_horizons if T <= 20]
        
        # Default probs should increase with horizon
        is_increasing = all(PDs[i] <= PDs[i+1] for i in range(len(PDs)-1))
        checks['PD_increasing'] = is_increasing
    
    return checks
