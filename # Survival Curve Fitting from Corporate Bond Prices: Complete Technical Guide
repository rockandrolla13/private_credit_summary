if len(bonds) == 3:
    # Use simpler model or regularization
    
    # Option 1: Fix β, fit λ₀ and λ₁ only
    beta_fixed = 0.35
    
    def objective_2param(params):
        lambda_0, lambda_1 = params
        theta = [lambda_0, lambda_1, beta_fixed]
        return standard_objective(theta)
    
    # Option 2: Add regularization penalty
    def objective_regularized(theta):
        residuals = standard_objective(theta)
        
        # Penalize extreme parameters
        lambda_0, lambda_1, beta = theta
        penalty = 0.01 * (lambda_0**2 + lambda_1**2)
        
        return np.append(residuals, penalty)
