def run_daily_survival_curve_batch(as_of_date: str):
    """
    Production batch process for all issuers.
    """
    import logging
    
    logger = logging.getLogger('survival_curves')
    logger.info(f"Starting batch for {as_of_date}")
    
    # Load data
    all_bonds = load_bonds_from_database(as_of_date)
    rf_curve = load_treasury_curve(as_of_date)
    
    logger.info(f"Loaded {len(all_bonds)} bonds")
    
    # Group by issuer
    issuer_bonds = defaultdict(list)
    for bond in all_bonds:
        issuer_bonds[bond.issuer_id].append(bond)
    
    logger.info(f"Found {len(issuer_bonds)} issuers")
    
    # Fit curves
    results = {}
    failed = []
    
    for issuer_id, bonds in issuer_bonds.items():
        if len(bonds) < 3:
            logger.debug(f"{issuer_id}: Only {len(bonds)} bonds, skipping")
            continue
        
        try:
            logger.info(f"Fitting {issuer_id} ({len(bonds)} bonds)")
            
            result = fit_survival_curve(bonds, rf_curve, verbose=False)
            
            if result['success'] and result['rmse'] < 5.0:
                results[issuer_id] = {
                    'theta': result['theta'],
                    'rmse': result['rmse'],
                    'n_bonds': len(bonds),
                    'validation': result['validation']
                }
                logger.info(f"  ✓ {issuer_id}: RMSE={result['rmse']:.2f}")
            else:
                failed.append(issuer_id)
                logger.warning(f"  ✗ {issuer_id}: Poor fit (RMSE={result['rmse']:.2f})")
        
        except Exception as e:
            failed.append(issuer_id)
            logger.error(f"  ✗ {issuer_id}: {str(e)}")
    
    # Save results
    save_curves_to_database(as_of_date, results)
    
    # Summary
    logger.info(f"Batch complete: {len(results)} successful, {len(failed)} failed")
    
    return {
        'date': as_of_date,
        'successful': results,
        'failed': failed
    }
