def validate_bond_data(bonds):
    """Check for data issues before fitting."""
    
    issues = []
    
    # Check 1: Minimum bond count
    if len(bonds) < 3:
        issues.append(f"Only {len(bonds)} bonds (need ≥3)")
    
    # Check 2: Maturity spread
    maturities = [b.maturity for b in bonds]
    if max(maturities) - min(maturities) < 2.0:
        issues.append(f"Maturity range only {max(maturities)-min(maturities):.1f} years")
    
    # Check 3: Price reasonableness
    for bond in bonds:
        if bond.price < 50 or bond.price > 150:
            issues.append(f"Bond {bond.isin}: suspicious price {bond.price}")
    
    # Check 4: Callable bonds have call schedules
    for bond in bonds:
        if bond.callable and not bond.call_schedule:
            issues.append(f"Bond {bond.isin}: callable but no call schedule")
    
    # Check 5: No duplicate bonds
    isins = [b.isin for b in bonds]
    if len(isins) != len(set(isins)):
        issues.append("Duplicate ISINs found")
    
    return issues
